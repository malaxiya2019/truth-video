<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF0D1117"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎓 TruthVideo"
        android:textSize="24sp"
        android:textColor="#FF58A6FF"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="离线教学视频渲染器"
        android:textSize="13sp"
        android:textColor="#FF8B949E"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📝 Markdown 内容"
        android:textColor="#FFE6EDF3"
        android:textSize="14sp"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/mdInput"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FF161B22"
        android:gravity="top"
        android:padding="12dp"
        android:scrollbars="vertical"
        android:textColor="#FFE6EDF3"
        android:textColorHint="#FF8B949E"
        android:textSize="12sp"
        android:inputType="textMultiLine"
        android:hint="# 标题\n\n## 场景1\n内容..."/>

    <Spinner
        android:id="@+id/themeSpinner"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:background="#FF161B22"/>

    <Button
        android:id="@+id/renderBtn"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#FF58A6FF"
        android:text="🚀 开始渲染"
        android:textColor="#FFFFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/statusTv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:padding="12dp"
        android:background="#FF161B22"
        android:text="💡 输入 Markdown，点击开始"
        android:textColor="#FF8B949E"
        android:textSize="13sp"
        android:minHeight="48dp"/>

</LinearLayout>
